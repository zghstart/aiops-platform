# AIOps Dashboard 环境配置示例
# 复制此文件为 .env.local 并填入实际值

# Java 控制面 API 地址
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Python AI 引擎 API 地址
VITE_AI_ENGINE_URL=http://localhost:8000/api/v1

# 应用标题
VITE_APP_TITLE=AIOps 智能运维平台

# 租户 ID (多租户场景)
VITE_TENANT_ID=default

# 是否启用 Mock 数据 (开发时可用)
VITE_ENABLE_MOCK=false
